{
  "paths": {
    "/auth/token": {
      "post": {
        "tags": ["Auth"],
        "summary": "Generate access token",
        "description": "Generate a simple bearer token for protected endpoints",
        "responses": {
          "200": {
            "description": "Token generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          }
        }
      }
    }
  },

  "components": {
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "token generated"
          },
          "data": {
            "type": "object",
            "properties": {
              "token": {
                "type": "string",
                "example": "secret-token"
              }
            }
          }
        }
      }
    }
  }
}